# Compiled binaries and Go test cache
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Coverage and profiling
*.prof
coverage.out
coverage.html
*.coverprofile

# Editor / OS detritus
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

